---
/**
 * BlogPost.astro — layout de un artículo del blog.
 * Renderiza: breadcrumb, H1, meta, caja de respuesta directa (AEO),
 * tabla de contenido automática (desde los H2), cuerpo (slot), FAQ y CTA.
 * Inyecta JSON-LD Article + BreadcrumbList + FAQPage vía Content → Base.
 */
import Content from './Content.astro';
import { articleSchema, faqPageSchema, breadcrumbSchema } from '../lib/schema.js';

export interface Props {
  entry: any;
  headings: { depth: number; slug: string; text: string }[];
}
const { entry, headings } = Astro.props;
const { data } = entry;

const url = `/blog/${entry.id}/`;
const fullUrl = new URL(url, 'https://santiagogil.com.mx').href;
const datePublished = data.pubDate.toISOString();
const dateModified = (data.updatedDate ?? data.pubDate).toISOString();
const fmtDate = data.pubDate.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const toc = headings.filter((h) => h.depth === 2);
const words = String(entry.body ?? '').split(/\s+/).filter(Boolean).length;
const readMin = Math.max(1, Math.round(words / 200));

const jsonLd = [
  articleSchema({
    title: data.title,
    description: data.description,
    url: fullUrl,
    datePublished,
    dateModified,
    image: data.image,
  }),
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Blog', url: '/blog/' },
    { name: data.title, url },
  ]),
];
if (data.faqs && data.faqs.length) jsonLd.push(faqPageSchema(data.faqs));
---
<Content
  title={`${data.title} | Santiago Gil`}
  description={data.description}
  canonical={url}
  image={data.image}
  type="article"
  jsonLd={jsonLd}
>
  <article class="article container">
    <nav class="breadcrumb" aria-label="Ruta de navegación">
      <a href="/">Inicio</a> › <a href="/blog/">Blog</a> › <span>{data.clusterLabel}</span>
    </nav>

    <div class="page-hero" style="padding-bottom:8px;">
      <span class="eyebrow">{data.clusterLabel}</span>
      <h1>{data.title}</h1>
      <div class="article__meta">
        <span>Por Chago Gil</span>
        <span>{fmtDate}</span>
        <span>{readMin} min de lectura</span>
      </div>
    </div>

    <div class="answer-box">
      <span class="answer-box__label">Respuesta corta</span>
      {data.answer}
    </div>

    <div class="article__layout">
      <div class="prose">
        <slot />
      </div>
      {toc.length > 0 && (
        <aside class="toc" aria-label="Tabla de contenido">
          <p class="toc__title">En esta guía</p>
          <ul>
            {toc.map((h) => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ul>
        </aside>
      )}
    </div>

    {data.faqs && data.faqs.length > 0 && (
      <section class="faq" aria-label="Preguntas frecuentes">
        <h2>Preguntas frecuentes</h2>
        {data.faqs.map((f: { question: string; answer: string }) => (
          <details>
            <summary>{f.question}</summary>
            <p>{f.answer}</p>
          </details>
        ))}
      </section>
    )}

    <div class="cta-box">
      <h3>¿Tienes una marca que construir?</h3>
      <p>Branding, identidad y estrategia para negocios en crecimiento. CDMX y remoto.</p>
      <a href="/#contacto" class="btn">Hablemos</a>
    </div>
  </article>
</Content>
