---
/**
 * Base.astro — layout raíz con SEO completo.
 * Centraliza title, description, canonical, hreflang, Open Graph, Twitter Card,
 * favicons e inyección de JSON-LD. Las páginas pasan su meta por props y, si
 * necesitan etiquetas extra en <head>, usan el slot nombrado "head".
 */
import Analytics from '../components/Analytics.astro';
// Inter self-hosted (sin petición bloqueante a Google Fonts).
import '@fontsource/inter/300.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';

export interface Props {
  title: string;
  description: string;
  /** Ruta o URL canónica. Si se omite, se deriva de Astro.url. */
  canonical?: string;
  /** Imagen para OG/Twitter (ruta absoluta o URL). */
  image?: string;
  type?: 'website' | 'profile' | 'article';
  keywords?: string;
  noindex?: boolean;
  /** Bloques JSON-LD a inyectar (array de objetos schema.org). */
  jsonLd?: Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  image = '/icon-512.png',
  type = 'website',
  keywords,
  noindex = false,
  jsonLd = [],
} = Astro.props;

const site = Astro.site ?? new URL('https://santiagogil.com.mx');
const canonicalURL = new URL(canonical ?? Astro.url.pathname, site).href;
const imageURL = new URL(image, site).href;
const robots = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <meta name="author" content="Santiago Gil" />
  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="es-MX" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={imageURL} />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:site_name" content="Santiago Gil" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={imageURL} />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png?v=2" />
  <link rel="icon" type="image/png" sizes="512x512" href="/icon-512.png?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />

  <!-- Fuentes: Inter self-hosted vía @fontsource (importado en el frontmatter). -->


  <!-- JSON-LD (schema.org) para AEO/GEO -->
  {jsonLd.map((block) => (
    <script type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  <Analytics />

  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
