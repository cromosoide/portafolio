---
/**
 * Analytics.astro — inyecta GA4, Microsoft Clarity y la verificación de
 * Search Console SOLO cuando hay IDs en src/consts.js. Vacío = no se inyecta.
 */
import { ANALYTICS } from '../consts.js';
const { GA4_ID, CLARITY_ID, GSC_VERIFICATION } = ANALYTICS;
---
{GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}

{GA4_ID && (
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
)}
{GA4_ID && (
  <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_ID}');`}></script>
)}

{CLARITY_ID && (
  <script is:inline set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${CLARITY_ID}");`}></script>
)}
