---
import Content from '../../layouts/Content.astro';
import { breadcrumbSchema } from '../../lib/schema.js';

const activas = [
  {
    slug: 'calculadora-presupuesto-branding',
    name: 'Calculadora de presupuesto de branding',
    desc: 'Estima un rango de inversión para tu proyecto de marca según tipo, tamaño y alcance web.',
  },
  {
    slug: 'validador-llms-txt',
    name: 'Validador de llms.txt',
    desc: 'Revisa si tu archivo llms.txt cumple la estructura que esperan los modelos de lenguaje.',
  },
  {
    slug: 'test-logo-8px',
    name: 'Test de logo a 8 px',
    desc: 'Sube tu logo y comprueba si se lee a tamaños mínimos (favicon, ícono, avatar).',
  },
  {
    slug: 'generador-de-paleta',
    name: 'Generador de paleta desde imagen',
    desc: 'Extrae los colores dominantes de una imagen con sus códigos hexadecimales.',
  },
  {
    slug: 'auditoria-eeat',
    name: 'Auditoría E-E-A-T rápida',
    desc: 'Checklist puntuable de experiencia, autoridad y confianza para tu página o sitio.',
  },
];

const jsonLd = [
  breadcrumbSchema([
    { name: 'Inicio', url: '/' },
    { name: 'Herramientas', url: '/herramientas/' },
  ]),
];
---
<Content
  title="Herramientas gratuitas de branding y AI SEO | Santiago Gil"
  description="5 herramientas gratuitas para branding y AI SEO: presupuesto de branding, validador de llms.txt, test de logo a 8 px, paleta desde imagen y auditoría E-E-A-T."
  canonical="/herramientas/"
  jsonLd={jsonLd}
>
  <section class="container page-hero">
    <span class="eyebrow">Herramientas</span>
    <h1>Herramientas gratuitas</h1>
    <p class="lede">Cinco utilidades para presupuestar marca, revisar tu logo y preparar tu sitio para la búsqueda con IA. Sin registro, todo en tu navegador.</p>
  </section>

  <section class="container" style="padding-bottom: 48px;">
    <div class="card-grid">
      {activas.map((t) => (
        <article class="card">
          <span class="tag">Disponible</span>
          <h3><a href={`/herramientas/${t.slug}/`}>{t.name}</a></h3>
          <p>{t.desc}</p>
          <a href={`/herramientas/${t.slug}/`}>Abrir herramienta →</a>
        </article>
      ))}
    </div>
  </section>
</Content>
